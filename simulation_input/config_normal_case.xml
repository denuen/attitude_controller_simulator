<?xml version="1.0" encoding="UTF-8"?>
<!--
  Normal case: representative conditions (standard noise, no drift, typical
  20 ms actuator delay), moderate mildly-asymmetric inertia, realistic mission
  profile. Gains tuned for a balanced response (wn ~= 1.2 rad/s, zeta ~= 0.85).
-->
<AttitudeControllerConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <!-- PID gains per axis (x=pitch, y=yaw, z=roll) -->
    <ControllerGains>
        <Kp x="35.0" y="35.0" z="35.0" />
        <Ki x="1.5" y="1.5" z="1.5" />
        <Kd x="49.0" y="49.0" z="49.0" />
    </ControllerGains>

    <PhysicalProperties>
        <!-- Principal inertia (kg.m^2), body axes x=roll, y=pitch, z=yaw -->
        <Inertia x="20.0" y="18.0" z="24.0" />
    </PhysicalProperties>

    <SensorCharacteristics>
        <!-- Drift rate (rad/s) -->
        <DriftRate x="0.0" y="0.0" z="0.0" />
        <!-- Gaussian noise std-dev per axis (rad) -->
        <NoiseStdDev x="0.003" y="0.003" z="0.003" />
    </SensorCharacteristics>

    <ActuatorProperties>
        <!-- Transport delay (s) -->
        <Delay>0.02</Delay>
        <!-- Per-axis torque limit (Nm) -->
        <MaxTorquePerAxis x="22.0" y="22.0" z="24.0" />
        <!-- Global torque magnitude cap (Nm) -->
        <MaxTorqueMagnitude>34.0</MaxTorqueMagnitude>
    </ActuatorProperties>

    <ControllerParameters>
        <!-- Derivative low-pass smoothing [0..1] -->
        <Smoothing>0.4</Smoothing>
        <!-- Integral anti-windup time constant (s) -->
        <AntiWindup>0.2</AntiWindup>
    </ControllerParameters>

    <InitialConditions>
        <!-- Initial attitude (pitch, yaw, roll) in rad -->
        <Attitude x="0.06" y="-0.035" z="0.045" />
        <!-- Initial body rates (rad/s) -->
        <AngularVelocity x="0.01" y="-0.006" z="0.008" />
    </InitialConditions>

    <!-- Setpoints over time; times strictly increasing (s), angles in rad -->
    <SetpointSequence>
        <Setpoint time="0.0"  roll="0.0"  pitch="0.0"  yaw="0.0"  /> <!-- origin -->
        <Setpoint time="8.0"  roll="0.0"  pitch="0.52" yaw="0.0"  /> <!-- earth pointing -->
        <Setpoint time="16.0" roll="0.26" pitch="0.52" yaw="0.35" /> <!-- sun pointing with roll -->
        <Setpoint time="24.0" roll="0.44" pitch="0.17" yaw="0.35" /> <!-- comms attitude -->
        <Setpoint time="30.0" roll="0.0"  pitch="0.0"  yaw="0.0"  /> <!-- return to nadir -->
    </SetpointSequence>
</AttitudeControllerConfig>
