<?xml version="1.0" encoding="UTF-8"?>
<!--
  Worst case: challenging but stabilizable (high noise, small drift, 40 ms
  actuator delay), asymmetric inertia, aggressive multi-axis profile.
  Authority and gains sized so the loop still converges and the attitude stays
  clear of the +/-90 deg Euler singularity (wn ~= 1 rad/s, zeta ~= 0.8).
-->
<AttitudeControllerConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <!-- PID gains per axis (x=roll, y=pitch, z=yaw) -->
    <ControllerGains>
        <Kp x="30.0" y="30.0" z="30.0" />
        <Ki x="1.5" y="1.5" z="1.5" />
        <Kd x="48.0" y="48.0" z="48.0" />
    </ControllerGains>

    <PhysicalProperties>
        <!-- Principal inertia (kg.m^2), body axes x=roll, y=pitch, z=yaw -->
        <Inertia x="25.0" y="20.0" z="30.0" />
    </PhysicalProperties>

    <SensorCharacteristics>
        <!-- Drift rate (rad/s) -->
        <DriftRate x="0.00003" y="0.00003" z="0.00003" />
        <!-- Gaussian noise std-dev per axis (rad); high -->
        <NoiseStdDev x="0.006" y="0.006" z="0.006" />
    </SensorCharacteristics>

    <ActuatorProperties>
        <!-- Transport delay (s) -->
        <Delay>0.04</Delay>
        <!-- Per-axis torque limit (Nm) -->
        <MaxTorquePerAxis x="20.0" y="20.0" z="22.0" />
        <!-- Global torque magnitude cap (Nm) -->
        <MaxTorqueMagnitude>32.0</MaxTorqueMagnitude>
    </ActuatorProperties>

    <ControllerParameters>
        <!-- Derivative low-pass smoothing [0..1]; high to tame sensor noise -->
        <Smoothing>0.5</Smoothing>
        <!-- Integral anti-windup time constant (s) -->
        <AntiWindup>0.3</AntiWindup>
    </ControllerParameters>

    <InitialConditions>
        <!-- Initial attitude (roll, pitch, yaw) in rad; large deviation -->
        <Attitude x="0.18" y="0.15" z="-0.12" />
        <!-- Initial body rates (rad/s); high -->
        <AngularVelocity x="0.05" y="-0.04" z="0.06" />
    </InitialConditions>

    <!-- Setpoints over time; times strictly increasing (s), angles in rad -->
    <SetpointSequence>
        <Setpoint time="0.0"  roll="0.0"  pitch="0.0"   yaw="0.0"   /> <!-- origin -->
        <Setpoint time="8.0"  roll="0.0"  pitch="0.45"  yaw="0.0"   /> <!-- pitch up -->
        <Setpoint time="16.0" roll="0.0"  pitch="0.45"  yaw="0.4"   /> <!-- add yaw -->
        <Setpoint time="24.0" roll="0.35" pitch="0.45"  yaw="0.4"   /> <!-- add roll (multi-axis) -->
        <Setpoint time="32.0" roll="0.35" pitch="-0.35" yaw="0.4"   /> <!-- pitch reversal -->
        <Setpoint time="40.0" roll="0.35" pitch="-0.35" yaw="-0.25" /> <!-- yaw reversal -->
        <Setpoint time="48.0" roll="-0.4" pitch="-0.35" yaw="-0.25" /> <!-- roll reversal -->
        <Setpoint time="58.0" roll="0.0"  pitch="0.0"   yaw="0.0"   /> <!-- return to origin -->
    </SetpointSequence>
</AttitudeControllerConfig>
